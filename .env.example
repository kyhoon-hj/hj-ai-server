DATABASE_URL="postgresql://username:password@localhost:5432/hj-ai"
AWS_REGION="us-east-2"
BEDROCK_MODEL_ID="us.anthropic.claude-sonnet-4-6"
PORT="3000"

# Local development only. Prefer IAM roles in deployed AWS environments.
# Do not define optional AWS variables as empty strings.
# AWS_PROFILE="your-profile"
# AWS_ACCESS_KEY_ID="your-access-key-id"
# AWS_SECRET_ACCESS_KEY="your-secret-access-key"
# AWS_SESSION_TOKEN="your-session-token"
# Alternative Bedrock API key auth, if used instead of IAM credentials:
# AWS_BEARER_TOKEN_BEDROCK="your-bedrock-api-key"
