APP_PORT="11000"

POSTGRES_DB="hj_ai"
POSTGRES_USER="postgres"
POSTGRES_PASSWORD="postgres"
DOCKER_DATABASE_URL="postgresql://postgres:postgres@db:5432/hj_ai"

AWS_REGION="us-east-2"
BEDROCK_MODEL_ID="us.anthropic.claude-sonnet-4-6"

