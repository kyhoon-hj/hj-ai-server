DATABASE_URL="postgresql://username:password@host.docker.internal:5432/hj-ai"
PORT="11000"
AWS_REGION="us-east-2"
BEDROCK_MODEL_ID="us.anthropic.claude-sonnet-4-6"
BEDROCK_EMBEDDING_MODEL_ID="amazon.titan-embed-text-v2:0"
APPKEY_JWT_SECRET="replace-with-a-long-random-secret"
AWS_S3_BUCKET="your-s3-bucket"
AWS_S3_REGION="us-east-2"
AWS_S3_CDN_URL="https://cdn.example.com"

# Local development only. Prefer IAM roles in deployed AWS environments.
# Do not define optional AWS variables as empty strings.
# AWS_ACCESS_KEY_ID="your-access-key-id"
# AWS_SECRET_ACCESS_KEY="your-secret-access-key"
# AWS_SESSION_TOKEN="your-session-token"
# AWS_BEARER_TOKEN_BEDROCK="your-bedrock-api-key"
