generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model TestTable {
  id        Int      @id @default(autoincrement())
  name      String
  createdAt DateTime @default(now())

  @@map("test_table")
}

model AppInfo {
  id       String   @id @default(uuid()) @db.Uuid
  appname  String
  appkey   String
  appcode  String
  remark   String?
  createat DateTime @default(now())
  updateat DateTime @updatedAt

  @@map("appinfo")
}
