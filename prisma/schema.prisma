generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model TestTable {
  id        Int      @id @default(autoincrement())
  name      String
  createdAt DateTime @default(now())

  @@map("test_table")
}

model AppInfo {
  id       String   @id @default(uuid()) @db.Uuid
  appname  String
  appkey   String
  appcode  String
  remark   String?
  createat DateTime @default(now())
  updateat DateTime @updatedAt

  @@map("appinfo")
}

model BedrockSearchLog {
  id           String   @id @default(uuid()) @db.Uuid
  appcode      String
  searchword   String
  searchat     DateTime @default(now())
  responsetime Int
  inputtokens  Int?
  outputtokens Int?
  totaltokens  Int?

  @@index([appcode])
  @@index([searchat])
  @@map("bedrock_search_log")
}
